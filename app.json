{
  "expo": {
    "name": "Adriele Finance",
    "slug": "agt-clone",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "agtclone",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,

    "ios": {
      "supportsTablet": true
    },

    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0b0f14"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.agtcontroller.finance",
      "permissions": ["NOTIFICATIONS"]
    },

    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0b0f14",
          "image": "./assets/images/splash.png",
          "resizeMode": "contain"
        }
      ],
      "@react-native-community/datetimepicker"
    ],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },

    "extra": {
      "eas": {
        "projectId": "29476289-c335-40d7-8dda-ea778838340c"
      }
    }
  }
}